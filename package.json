{
  "name": "calculate",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "lint": "eslint .",
    "lint:suppressed": "node scripts/count-suppressions.js",
    "format": "eslint . --fix",
    "build": "pnpm lint && vite build && vite build --ssr src/entry-server.tsx --outDir dist/server && node scripts/prerender.js",
    "preview": "vite preview",
    "jscpd": "jscpd src",
    "test": "vitest run --coverage",
    "test:meta-compiler": "node scripts/meta-test-compiler.js",
    "knip": "knip"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^4.2.3",
    "@eslint/js": "^9.39.4",
    "@html-eslint/eslint-plugin": "^0.59.0",
    "@tailwindcss/postcss": "^4.2.3",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "autoprefixer": "^10.5.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-better-tailwindcss": "^4.4.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "fast-check": "^4.7.0",
    "globals": "^17.5.0",
    "jscpd": "^4.0.9",
    "jsdom": "^29.0.2",
    "knip": "^6.6.0",
    "neostandard": "^0.13.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.3",
    "typescript-eslint": "^8.0.0",
    "vite": "^8.0.9",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  }
}