{
  "name": "calculate",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "vite",
    "lint": "eslint . --cache",
    "lint:suppressed": "node scripts/count-suppressions.js",
    "format": "eslint . --fix --cache",
    "build": "pnpm lint && vite build && vite build --ssr src/entry-server.tsx --outDir dist/server && node scripts/prerender.js",
    "preview": "vite preview",
    "jscpd": "jscpd src",
    "test": "vitest run --coverage",
    "test:meta-compiler": "node scripts/meta-test-compiler.js",
    "knip": "knip",
    "quality": "concurrently --kill-others-on-fail \"pnpm:knip\" \"pnpm:test\" \"pnpm:jscpd\" \"pnpm:lint\""
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^4.2.3",
    "@eslint/js": "^10.0.1",
    "@html-eslint/eslint-plugin": "^0.59.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-legacy": "^8.0.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.5.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.1",
    "eslint-plugin-better-tailwindcss": "^4.4.1",
    "eslint-plugin-compat": "^7.0.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "fast-check": "^4.7.0",
    "globals": "^17.5.0",
    "jscpd": "^4.0.9",
    "jsdom": "^29.0.2",
    "knip": "^6.6.0",
    "neostandard": "^0.13.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.3",
    "terser": "^5.46.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.9",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "knip": {
    "entry": [
      "src/entry-server.tsx"
    ]
  },
  "pnpm": {
    "overrides": {
      "@babel/plugin-proposal-private-methods": "npm:@babel/plugin-transform-private-methods@^7.28.6",
      "zod-validation-error": "^5.0.0",
      "@stylistic/eslint-plugin": "^5.10.0"
    }
  },
  "browserslist": [
    "> 0.5%",
    "last 2 years",
    "Firefox ESR",
    "not dead"
  ]
}