<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>Math Crossword: Scrabble Edition</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
  <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
  <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
  <style>
    body {
      background-color: #f8fafc;
      touch-action: manipulation;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      -webkit-user-select: none;
      user-select: none;
      overflow: hidden;
    }

    /* The Board */
    .board-container {
      overflow: auto;
      -ms-overflow-style: none;
      scrollbar-width: none;
    }

    .board-container::-webkit-scrollbar {
      display: none;
    }

    /* Tiles */
    .tile {
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: bold;
      border-radius: 2px;
      box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
      transition: all 0.15s ease;
      cursor: pointer;
    }

    .tile:active {
      transform: scale(0.95);
    }

    .tile.selected {
      box-shadow: 0 0 0 3px rgba(249, 115, 22, 0.4);
      transform: scale(1.05);
      z-index: 10;
    }

    /* Types of Tiles */
    .tile-val {
      background-color: #ffffff;
      color: #166534;
      border: 1px solid #22c55e;
    }

    .tile-op {
      background-color: #fffbeb;
      color: #b45309;
      border: 1px solid #f59e0b;
    }

    .tile-rel {
      background-color: #eff6ff;
      color: #1d4ed8;
      border: 1px solid #3b82f6;
    }

    .tile-given {
      background-color: #1e293b;
      color: #ffffff;
      border: 1px solid #0f172a;
      cursor: default;
    }

    /* Empty Drop Zones (Fringe) */
    .fringe-slot {
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 2px;
      background-color: rgba(255, 255, 255, 0.5);
      border: 1px dashed #cbd5e1;
      cursor: pointer;
      transition: all 0.15s ease;
    }

    .fringe-slot.highlight {
      border-color: #f97316;
      background-color: rgba(255, 237, 213, 0.5);
    }

    /* Animations */
    @keyframes fadeIn {
      from {
        opacity: 0;
        transform: scale(0.9);
      }

      to {
        opacity: 1;
        transform: scale(1);
      }
    }

    .animate-fade-in {
      animation: fadeIn 0.3s ease-out forwards;
    }
  </style>
</head>

<body>
  <div id="root"></div>

  <script type="text/babel">
    const { useState, useEffect, useMemo, useRef } = React;

    // --- PRNG & Hashing ---
    const getHashSeed = (str) => {
      let h = 2166136261 >>> 0;
      for (let i = 0; i < str.length; i++) {
        h = Math.imul(h ^ str.charCodeAt(i), 16777619);
      }
      return h >>> 0;
    };

    function mulberry32(a) {
      return function () {
        var t = a += 0x6D2B79F5;
        t = Math.imul(t ^ t >>> 15, t | 1);
        t ^= t + Math.imul(t ^ t >>> 7, t | 61);
        return ((t ^ t >>> 14) >>> 0) / 4294967296;
      }
    }

    // --- Math Logic Helpers ---
    const generateValidStatement = (prng) => {
      const ops = ['+', '-', '*', '/'];

      let attempts = 0;
      while (attempts < 1000) {
        attempts++;
        let op = ops[Math.floor(prng() * ops.length)];

        let relRoll = prng();
        let rel = '=';
        if (relRoll > 0.75) {
          if (relRoll > 0.91) rel = '<>';
          else if (relRoll > 0.83) rel = '>';
          else rel = '<';
        }

        let A, B, val;

        if (op === '+') {
          A = 1 + Math.floor(prng() * 40);
          B = 1 + Math.floor(prng() * 40);
          val = A + B;
        } else if (op === '-') {
          B = 1 + Math.floor(prng() * 40);
          A = B + 1 + Math.floor(prng() * 40);
          val = A - B;
        } else if (op === '*') {
          A = 2 + Math.floor(prng() * 8);
          B = 2 + Math.floor(prng() * 9);
          val = A * B;
        } else if (op === '/') {
          B = 2 + Math.floor(prng() * 8);
          val = 2 + Math.floor(prng() * 9);
          A = B * val;
        }

        let C = val;
        if (rel === '<') {
          C = val + 1 + Math.floor(prng() * 15);
        } else if (rel === '>') {
          if (val <= 0) continue;
          C = Math.floor(prng() * val);
        } else if (rel === '<>') {
          C = val + (prng() > 0.5 ? 1 : -1) * (1 + Math.floor(prng() * 10));
          if (C < 0) C = val + 1;
        }

        if (A >= 100 || B >= 100 || C >= 100) continue;

        let tokens = [];
        tokens.push(...String(A).split(''));
        tokens.push(op);
        tokens.push(...String(B).split(''));

        if (rel === '<>') {
          tokens.push('<');
          tokens.push('>');
        } else {
          tokens.push(rel);
        }

        tokens.push(...String(C).split(''));

        if (tokens.length >= 5 && tokens.length <= 10) {
          return tokens;
        }
      }
      return ['1', '+', '2', '=', '3'];
    };

    const evaluateExpression = (str) => {
      if (str.length === 0) return null;
      if (/[+\-*/]{2,}/.test(str)) return null;
      if (/^[+\-*/]/.test(str)) return null;
      if (/[+\-*/]$/.test(str)) return null;
      if (!/^[0-9+\-*/]+$/.test(str)) return null;
      if (/(^|[+\-*/])0\d+/.test(str)) return null;

      let tokens = str.match(/\d+|[+\-*/]/g);
      if (!tokens) return null;

      let pass1 = [];
      for (let i = 0; i < tokens.length; i++) {
        let t = tokens[i];
        if (t === '*' || t === '/') {
          let left = pass1.pop();
          let right = Number(tokens[++i]);
          if (t === '*') {
            pass1.push(left * right);
          } else {
            if (right === 0) return null;
            if (left % right !== 0) return null;
            pass1.push(left / right);
          }
        } else if (/\d+/.test(t)) {
          pass1.push(Number(t));
        } else {
          pass1.push(t);
        }
      }

      let res = pass1[0];
      for (let i = 1; i < pass1.length; i += 2) {
        let op = pass1[i];
        let right = pass1[i + 1];
        if (op === '+') res += right;
        if (op === '-') res -= right;
      }

      if (typeof res !== 'number' || !isFinite(res)) return null;
      return res;
    };

    const isValidEquation = (wordTiles) => {
      let tokens = wordTiles.map(t => t.val);

      let relType = null;
      let relStart = -1;
      let relEnd = -1;

      for (let i = 0; i < tokens.length; i++) {
        let t = tokens[i];
        if (t === '=' || t === '<' || t === '>') {
          if (relType !== null) {
            if (relType === '<' && t === '>' && i === relEnd + 1) {
              relType = '<>';
              relEnd = i;
              continue;
            }
            return false;
          } else {
            relType = t;
            relStart = i;
            relEnd = i;
          }
        }
      }

      if (relType === null) return false;
      if (relStart === 0 || relEnd === tokens.length - 1) return false;

      let leftSide = tokens.slice(0, relStart).join('');
      let rightSide = tokens.slice(relEnd + 1).join('');

      let leftVal = evaluateExpression(leftSide);
      let rightVal = evaluateExpression(rightSide);

      if (leftVal === null || rightVal === null) return false;

      if (relType === '=') return Math.abs(leftVal - rightVal) < 0.0001;
      if (relType === '<') return leftVal < rightVal;
      if (relType === '>') return leftVal > rightVal;
      if (relType === '<>') return Math.abs(leftVal - rightVal) >= 0.0001;

      return false;
    };

    const validateBoard = (board) => {
      let placedKeys = Object.keys(board);
      if (placedKeys.length === 0) return { valid: false, reason: "Board is empty." };

      let visited = new Set();
      let queue = [placedKeys[0]];
      visited.add(placedKeys[0]);

      while (queue.length > 0) {
        let [r, c] = queue.shift().split(',').map(Number);
        let neighbors = [
          `${r + 1},${c}`,
          `${r - 1},${c}`,
          `${r},${c + 1}`,
          `${r},${c - 1}`
        ];

        for (let nk of neighbors) {
          if (board[nk] && !visited.has(nk)) {
            visited.add(nk);
            queue.push(nk);
          }
        }
      }

      if (visited.size !== placedKeys.length) return { valid: false, reason: "All tiles must be connected together." };

      let minR = Infinity, maxR = -Infinity, minC = Infinity, maxC = -Infinity;
      for (let k of placedKeys) {
        let [r, c] = k.split(',').map(Number);
        minR = Math.min(minR, r); maxR = Math.max(maxR, r);
        minC = Math.min(minC, c); maxC = Math.max(maxC, c);
      }

      let validTiles = new Set();
      let equationsCount = 0;

      const checkWord = (word) => {
        if (word.length >= 3 && isValidEquation(word)) {
          equationsCount++;
          word.forEach(t => validTiles.add(t.key));
        }
      };

      for (let r = minR; r <= maxR; r++) {
        let currentWord = [];
        for (let c = minC; c <= maxC + 1; c++) {
          let cell = board[`${r},${c}`];
          if (cell) {
            currentWord.push({ key: `${r},${c}`, ...cell });
          } else {
            if (currentWord.length > 0) checkWord(currentWord);
            currentWord = [];
          }
        }
      }

      for (let c = minC; c <= maxC; c++) {
        let currentWord = [];
        for (let r = minR; r <= maxR + 1; r++) {
          let cell = board[`${r},${c}`];
          if (cell) {
            currentWord.push({ key: `${r},${c}`, ...cell });
          } else {
            if (currentWord.length > 0) checkWord(currentWord);
            currentWord = [];
          }
        }
      }

      if (equationsCount === 0) return { valid: false, reason: "No valid mathematical equations found." };

      for (let k of placedKeys) {
        if (!validTiles.has(k)) {
          return { valid: false, reason: "Some tiles don't form a correct equation." };
        }
      }

      return { valid: true };
    };

    // --- Generator Logic ---
    const placeEquation = (grid, equations, prng) => {
      for (let attempt = 0; attempt < 50; attempt++) {
        let stmt = generateValidStatement(prng);

        let possibleIntersections = [];
        for (let k in grid) {
          let cellVal = String(grid[k].val);
          for (let i = 0; i < stmt.length; i++) {
            if (stmt[i] === cellVal) {
              possibleIntersections.push({ k, idx: i });
            }
          }
        }

        possibleIntersections.sort(() => prng() - 0.5);

        for (let match of possibleIntersections) {
          let [r, c] = match.k.split(',').map(Number);

          let hasHoriz = equations.some(eq => eq.cells.includes(match.k) && eq.dx === 1);
          let hasVert = equations.some(eq => eq.cells.includes(match.k) && eq.dy === 1);

          let dirs = [];
          if (!hasHoriz) dirs.push({ dx: 1, dy: 0 });
          if (!hasVert) dirs.push({ dx: 0, dy: 1 });
          dirs.sort(() => prng() - 0.5);

          for (let dir of dirs) {
            let startR = r - match.idx * dir.dy;
            let startC = c - match.idx * dir.dx;

            let cells = [];
            let collision = false;
            for (let i = 0; i < stmt.length; i++) {
              let cr = startR + i * dir.dy;
              let cc = startC + i * dir.dx;
              let ck = `${cr},${cc}`;
              cells.push(ck);

              if (i === match.idx) {
                if (ck !== match.k) collision = true;
              } else {
                if (grid[ck]) { collision = true; break; }
                let neighbors = [`${cr + 1},${cc}`, `${cr - 1},${cc}`, `${cr},${cc + 1}`, `${cr},${cc - 1}`];
                for (let nk of neighbors) {
                  if (grid[nk] && nk !== match.k) {
                    let inNewEq = false;
                    for (let j = 0; j < stmt.length; j++) {
                      if (`${startR + j * dir.dy},${startC + j * dir.dx}` === nk) inNewEq = true;
                    }
                    if (!inNewEq) { collision = true; break; }
                  }
                }
              }
              if (collision) break;
            }

            if (!collision) {
              let minR = Infinity, maxR = -Infinity, minC = Infinity, maxC = -Infinity;
              for (let k in grid) {
                let [gr, gc] = k.split(',').map(Number);
                minR = Math.min(minR, gr); maxR = Math.max(maxR, gr);
                minC = Math.min(minC, gc); maxC = Math.max(maxC, gc);
              }
              for (let k of cells) {
                let [cr, cc] = k.split(',').map(Number);
                minR = Math.min(minR, cr); maxR = Math.max(maxR, cr);
                minC = Math.min(minC, cc); maxC = Math.max(maxC, cc);
              }
              if (maxR - minR + 1 > 10 || maxC - minC + 1 > 10) {
                collision = true;
              }
            }

            if (!collision) {
              for (let i = 0; i < stmt.length; i++) {
                let char = stmt[i];
                let type = 'val';
                if (['+', '-', '*', '/'].includes(char)) type = 'op';
                if (['=', '<', '>'].includes(char)) type = 'rel';
                grid[cells[i]] = { type, val: char };
              }
              equations.push({ cells, dx: dir.dx, dy: dir.dy });
              return true;
            }
          }
        }
      }
      return false;
    };

    const generateGame = (stage, difficulty) => {
      let seedStr = `${difficulty}_${stage}`;
      let prng = mulberry32(getHashSeed(seedStr));

      let diffPercent, minInv, maxInv;
      if (difficulty === 'Easy') {
        diffPercent = 0.60; minInv = 5; maxInv = 7;
      } else if (difficulty === 'Medium') {
        diffPercent = 0.40; minInv = 10; maxInv = 14;
      } else {
        diffPercent = 0.20; minInv = 15; maxInv = 21;
      }

      let targetInv = minInv + Math.floor(prng() * (maxInv - minInv + 1));
      let targetTotalTiles = Math.ceil(targetInv / (1 - diffPercent));

      let bestGrid = null;

      for (let attempt = 0; attempt < 30; attempt++) {
        let grid = {};
        let equations = [];
        let stmt = generateValidStatement(prng);

        for (let i = 0; i < stmt.length; i++) {
          let char = stmt[i];
          let type = 'val';
          if (['+', '-', '*', '/'].includes(char)) type = 'op';
          if (['=', '<', '>'].includes(char)) type = 'rel';
          grid[`0,${i}`] = { type, val: char };
        }
        equations.push({ dx: 1, dy: 0, cells: stmt.map((_, i) => `0,${i}`) });

        let fails = 0;
        while (Object.keys(grid).length < targetTotalTiles && fails < 40) {
          if (!placeEquation(grid, equations, prng)) fails++;
        }

        if (!bestGrid || Object.keys(grid).length > Object.keys(bestGrid).length) {
          bestGrid = grid;
        }

        if (Object.keys(grid).length >= targetTotalTiles) {
          break;
        }
      }

      if (!bestGrid) {
        bestGrid = {
          "0,0": { type: 'val', val: '2' }, "0,1": { type: 'op', val: '+' },
          "0,2": { type: 'val', val: '3' }, "0,3": { type: 'rel', val: '=' },
          "0,4": { type: 'val', val: '5' }
        };
      }

      let board = {};
      let bank = [];

      let totalTiles = Object.keys(bestGrid).length;
      let numGivens = Math.round(totalTiles * diffPercent);
      let numInventory = totalTiles - numGivens;

      if (numInventory < minInv) {
        numInventory = Math.min(totalTiles - 1, minInv);
        numGivens = totalTiles - numInventory;
      } else if (numInventory > maxInv) {
        numInventory = maxInv;
        numGivens = totalTiles - numInventory;
      }
      if (numGivens < 0) numGivens = 0;

      let minR = Infinity, maxR = -Infinity, minC = Infinity, maxC = -Infinity;
      for (let k in bestGrid) {
        let [r, c] = k.split(',').map(Number);
        minR = Math.min(minR, r); maxR = Math.max(maxR, r);
        minC = Math.min(minC, c); maxC = Math.max(maxC, c);
      }

      let allKeys = Object.keys(bestGrid);
      let givenKeys = new Set();
      let safeGivens = false;
      let givenAttempts = 0;

      while (!safeGivens && givenAttempts < 200) {
        givenAttempts++;
        allKeys.sort(() => prng() - 0.5);
        givenKeys = new Set(allKeys.slice(0, numGivens));

        let tempBoard = {};
        for (let k of givenKeys) tempBoard[k] = bestGrid[k];

        let foundTrueStatement = false;

        for (let r = minR; r <= maxR; r++) {
          let word = [];
          for (let c = minC; c <= maxC + 1; c++) {
            if (tempBoard[`${r},${c}`]) {
              word.push({ val: tempBoard[`${r},${c}`].val });
            } else {
              if (word.length >= 3 && isValidEquation(word)) foundTrueStatement = true;
              word = [];
            }
          }
        }

        for (let c = minC; c <= maxC; c++) {
          let word = [];
          for (let r = minR; r <= maxR + 1; r++) {
            if (tempBoard[`${r},${c}`]) {
              word.push({ val: tempBoard[`${r},${c}`].val });
            } else {
              if (word.length >= 3 && isValidEquation(word)) foundTrueStatement = true;
              word = [];
            }
          }
        }

        if (!foundTrueStatement) {
          safeGivens = true;
        }
      }

      for (let k in bestGrid) {
        let cell = bestGrid[k];
        if (givenKeys.has(k)) {
          board[k] = { id: `g_${k}`, ...cell, isGiven: true };
        } else {
          bank.push({ id: `b_${k}`, val: cell.val, type: cell.type });
        }
      }

      bank.sort((a, b) => {
        let w = (t) => t.type === 'val' ? 1 : t.type === 'op' ? 2 : 3;
        if (w(a) !== w(b)) return w(a) - w(b);
        if (a.type === 'val') return String(a.val).localeCompare(String(b.val));
        return String(a.val).localeCompare(String(b.val));
      });

      return { board, bank, initialBankSize: bank.length, status: 'playing' };
    };

    // --- React App ---
    const App = () => {
      const [difficulty, setDifficulty] = useState('Medium');
      const [progress, setProgress] = useState({
        Easy: { current: 1, max: 1 },
        Medium: { current: 1, max: 1 },
        Hard: { current: 1, max: 1 }
      });

      const currentStage = progress[difficulty].current;
      const maxStage = progress[difficulty].max;

      const [gameState, setGameState] = useState(null);
      const [selectedTileId, setSelectedTileId] = useState(null);
      const [toast, setToast] = useState(null);

      const boardContainerRef = useRef(null);

      const handleDifficultyChange = (e) => {
        const newDiff = e.target.value;
        setDifficulty(newDiff);
        setProgress(prev => ({
          ...prev,
          [newDiff]: {
            ...prev[newDiff],
            current: prev[newDiff].max
          }
        }));
      };

      const changeStage = (delta) => {
        setProgress(prev => ({
          ...prev,
          [difficulty]: {
            ...prev[difficulty],
            current: prev[difficulty].current + delta
          }
        }));
      };

      useEffect(() => {
        setGameState({ ...generateGame(currentStage, difficulty), solvedAcknowledged: false });
        setSelectedTileId(null);
        setToast(null);
      }, [currentStage, difficulty]);

      useEffect(() => {
        if (gameState?.status === 'playing' && gameState.bank.length === gameState.initialBankSize && boardContainerRef.current) {
          const el = boardContainerRef.current;
          el.scrollTop = (el.scrollHeight - el.clientHeight) / 2;
          el.scrollLeft = (el.scrollWidth - el.clientWidth) / 2;
        }
      }, [gameState]);

      useEffect(() => {
        if (!gameState || gameState.status !== 'playing') return;

        let timer;
        if (gameState.bank.length === 0 && !gameState.solvedAcknowledged) {
          const validation = validateBoard(gameState.board);
          if (validation.valid) {
            setProgress(prev => {
              const diffProgress = prev[difficulty];
              if (diffProgress.current === diffProgress.max) {
                return {
                  ...prev,
                  [difficulty]: {
                    ...diffProgress,
                    max: diffProgress.max + 1
                  }
                };
              }
              return prev;
            });

            setGameState(prev => ({ ...prev, status: 'won' }));
            setSelectedTileId(null);
            setToast(null);
          } else {
            setToast(validation.reason);
            timer = setTimeout(() => setToast(null), 3500);
          }
        } else {
          setToast(null);
        }

        return () => clearTimeout(timer);
      }, [gameState?.board, gameState?.bank, gameState?.solvedAcknowledged, difficulty]);

      const handleBoardClick = (key) => {
        if (gameState.status !== 'playing') return;

        let cell = gameState.board[key];
        if (cell && cell.isGiven) return;

        setGameState(prev => {
          let next = { ...prev, board: { ...prev.board }, bank: [...prev.bank], solvedAcknowledged: false };

          if (selectedTileId) {
            let bankIdx = next.bank.findIndex(t => t.id === selectedTileId);
            if (bankIdx === -1) return prev;
            let tile = next.bank[bankIdx];

            if (cell) {
              next.bank[bankIdx] = { id: cell.id, val: cell.val, type: cell.type };
            } else {
              next.bank.splice(bankIdx, 1);
            }

            next.board[key] = { id: tile.id, val: tile.val, type: tile.type, isGiven: false };
            setSelectedTileId(null);

          } else if (cell) {
            next.bank.push({ id: cell.id, val: cell.val, type: cell.type });
            delete next.board[key];

            next.bank.sort((a, b) => {
              let w = (t) => t.type === 'val' ? 1 : t.type === 'op' ? 2 : 3;
              if (w(a) !== w(b)) return w(a) - w(b);
              if (a.type === 'val') return String(a.val).localeCompare(String(b.val));
              return String(a.val).localeCompare(String(b.val));
            });
          }

          return next;
        });
      };

      const resetLevel = () => {
        setGameState({ ...generateGame(currentStage, difficulty), solvedAcknowledged: false });
        setSelectedTileId(null);
      };

      const groupedBank = useMemo(() => {
        if (!gameState) return [];
        const groups = [];
        const groupMap = {};
        for (let tile of gameState.bank) {
          if (!groupMap[tile.val]) {
            groupMap[tile.val] = { val: tile.val, type: tile.type, tiles: [] };
            groups.push(groupMap[tile.val]);
          }
          groupMap[tile.val].tiles.push(tile);
        }
        return groups;
      }, [gameState?.bank]);

      if (!gameState) return <div className="flex h-screen items-center justify-center font-bold text-slate-500">Generating Puzzle...</div>;

      const { board, bank, status } = gameState;

      let minR = Infinity, maxR = -Infinity, minC = Infinity, maxC = -Infinity;
      let fringe = new Set();

      Object.keys(board).forEach(k => {
        let [r, c] = k.split(',').map(Number);
        minR = Math.min(minR, r); maxR = Math.max(maxR, r);
        minC = Math.min(minC, c); maxC = Math.max(maxC, c);

        [[r + 1, c], [r - 1, c], [r, c + 1], [r, c - 1]].forEach(([nr, nc]) => {
          let nk = `${nr},${nc}`;
          if (!board[nk]) fringe.add(nk);
        });
      });

      fringe.forEach(k => {
        let [r, c] = k.split(',').map(Number);
        minR = Math.min(minR, r); maxR = Math.max(maxR, r);
        minC = Math.min(minC, c); maxC = Math.max(maxC, c);
      });

      minR -= 1; maxR += 1;
      minC -= 1; maxC += 1;

      const cols = maxC - minC + 1;
      const rows = maxR - minR + 1;

      return (
        <div className="h-screen w-full flex flex-col">
          <div className="flex justify-between items-center p-3 sm:p-4 bg-white shadow-sm z-20 shrink-0">
            <div className="flex items-center gap-2 sm:gap-3">
              <h1 className="text-xl font-extrabold text-slate-800 tracking-tight hidden md:block">Math Scrabble</h1>

              <div className="flex items-center bg-indigo-50 rounded-full shadow-inner border border-indigo-100">
                <button
                  onClick={() => changeStage(-1)}
                  disabled={currentStage <= 1}
                  className="px-2 sm:px-3 py-1.5 text-indigo-600 hover:bg-indigo-100 disabled:opacity-30 disabled:hover:bg-transparent transition-colors font-bold rounded-l-full"
                  aria-label="Previous Stage"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="3" strokeLinecap="round" strokeLinejoin="round"><path d="m15 18-6-6 6-6" /></svg>
                </button>
                <span className="px-2 sm:px-3 py-1 text-indigo-800 text-sm font-bold border-x border-indigo-200/50 whitespace-nowrap min-w-[70px] text-center">
                  Stage {currentStage}
                </span>
                <button
                  onClick={() => changeStage(1)}
                  disabled={currentStage >= maxStage}
                  className="px-2 sm:px-3 py-1.5 text-indigo-600 hover:bg-indigo-100 disabled:opacity-30 disabled:hover:bg-transparent transition-colors font-bold rounded-r-full"
                  aria-label="Next Stage"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="3" strokeLinecap="round" strokeLinejoin="round"><path d="m9 18 6-6-6-6" /></svg>
                </button>
              </div>

              <select
                value={difficulty}
                onChange={handleDifficultyChange}
                className="bg-slate-100 border border-slate-300 text-slate-700 text-sm rounded-lg focus:ring-indigo-500 focus:border-indigo-500 block px-2 sm:px-2.5 py-1 font-medium"
              >
                <option value="Easy">Easy</option>
                <option value="Medium">Medium</option>
                <option value="Hard">Hard</option>
              </select>
            </div>
            <button
              onClick={resetLevel}
              className="p-2 text-slate-500 hover:text-slate-800 hover:bg-slate-100 transition-colors rounded-full shrink-0 ml-2"
              aria-label="Reset Stage"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8" /><path d="M3 3v5h5" /></svg>
            </button>
          </div>

          <div className="flex-1 relative bg-slate-50 board-container overflow-auto" ref={boardContainerRef}>
            <div
              className="m-auto p-8 flex items-center justify-center animate-fade-in min-h-full min-w-full w-fit"
            >
              <div
                className="grid gap-0"
                style={{
                  gridTemplateColumns: `repeat(${cols}, 2.75rem)`,
                  gridTemplateRows: `repeat(${rows}, 2.75rem)`
                }}
              >
                {Array.from({ length: rows * cols }).map((_, i) => {
                  let r = Math.floor(i / cols) + minR;
                  let c = (i % cols) + minC;
                  let key = `${r},${c}`;
                  let cell = board[key];
                  let isFringe = fringe.has(key);

                  if (!cell && !isFringe) {
                    return <div key={key} className="w-full h-full pointer-events-none" />;
                  }

                  if (!cell && isFringe) {
                    return (
                      <div
                        key={key}
                        onClick={() => handleBoardClick(key)}
                        className={`fringe-slot ${selectedTileId ? 'highlight' : ''}`}
                      />
                    );
                  }

                  let content = cell.val === '*' ? '×' : cell.val === '/' ? '÷' : cell.val;
                  let typeClass = cell.isGiven ? 'tile-given' : `tile-${cell.type}`;

                  return (
                    <div
                      key={key}
                      onClick={() => handleBoardClick(key)}
                      className={`tile ${typeClass} text-lg md:text-xl animate-fade-in`}
                    >
                      {content}
                    </div>
                  );
                })}
              </div>
            </div>

            {toast && (
              <div className="fixed bottom-28 left-1/2 transform -translate-x-1/2 bg-slate-800 text-white px-6 py-3 rounded-full shadow-2xl z-[60] animate-fade-in font-medium text-sm md:text-base whitespace-nowrap">
                {toast}
              </div>
            )}

            {status === 'won' && (
              <div className="absolute inset-0 bg-white/90 backdrop-blur-sm z-50 flex flex-col items-center justify-center animate-fade-in p-4">
                <h2 className="text-4xl md:text-5xl font-black text-indigo-600 mb-2 drop-shadow-sm tracking-tight text-center">Perfect!</h2>
                <p className="text-slate-600 mb-8 font-medium text-base md:text-lg text-center">You cleared the board.</p>
                <div className="flex flex-col sm:flex-row gap-3 sm:gap-4 w-full sm:w-auto max-w-xs sm:max-w-none">
                  <button
                    onClick={() => setGameState(prev => ({ ...prev, status: 'playing', solvedAcknowledged: true }))}
                    className="bg-slate-200 hover:bg-slate-300 text-slate-700 font-bold py-3 px-6 rounded-full shadow-md transform transition active:scale-95 text-base md:text-lg"
                  >
                    Keep Playing
                  </button>
                  <button
                    onClick={() => changeStage(1)}
                    className="bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-3 px-8 rounded-full shadow-xl transform transition active:scale-95 text-base md:text-lg"
                  >
                    Next Stage
                  </button>
                </div>
              </div>
            )}
          </div>

          <div className="bg-white border-t border-slate-200 shadow-[0_-4px_15px_-5px_rgba(0,0,0,0.1)] shrink-0 z-20 pb-safe">
            <div className="max-w-4xl mx-auto p-4 md:p-6 overflow-x-auto board-container">
              <div className="flex flex-wrap justify-center gap-3 md:gap-4 min-w-min pb-2">
                {groupedBank.map((group) => {
                  let content = group.val === '*' ? '×' : group.val === '/' ? '÷' : group.val;
                  let isSelected = selectedTileId && group.tiles.some(t => t.id === selectedTileId);
                  let count = group.tiles.length;

                  return (
                    <div key={group.val} className="relative m-1 inline-block">
                      {count > 1 && (
                        <div className={`absolute top-1 left-1 w-full h-full rounded-[2px] tile-${group.type} pointer-events-none`} />
                      )}

                      <button
                        onClick={() => {
                          if (gameState.status !== 'playing') return;
                          if (isSelected) {
                            setSelectedTileId(null);
                          } else {
                            setSelectedTileId(group.tiles[0].id);
                          }
                        }}
                        className={`
                                                    tile tile-${group.type} w-12 h-12 sm:w-14 sm:h-14 
                                                    text-xl sm:text-2xl flex-shrink-0 relative z-10
                                                    ${isSelected ? 'selected' : ''}
                                                `}
                      >
                        {content}
                      </button>

                      {count > 1 && (
                        <div className="absolute -top-2.5 -right-2.5 bg-indigo-600 text-white text-[10px] sm:text-xs font-bold h-5 sm:h-6 min-w-[20px] sm:min-w-[24px] px-1.5 flex items-center justify-center rounded-full z-20 shadow-md border-2 border-white pointer-events-none">
                          {count}
                        </div>
                      )}
                    </div>
                  );
                })}
                {groupedBank.length === 0 && (
                  <div className="text-slate-400 font-medium italic py-3 px-4">
                    Bank is empty.
                  </div>
                )}
              </div>
            </div>
          </div>
        </div>
      );
    };

    const root = ReactDOM.createRoot(document.getElementById('root'));
    root.render(<App />);
  </script>
</body>

</html>